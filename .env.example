# JWT
JWT_SECRET_KEY=change_me_with_a_strong_random_key
JWT_REFRESH_SECRET_KEY=change_me_with_another_strong_random_key

# MongoDB
MONGO_CONNECTION_STRING=mongodb://mongo:27017

# Mail
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=your_email@example.com
MAIL_SERVER=smtp.example.com

# URLs
FRONT_END_URL=https://garden.jammin-dev.com
BACK_END_URL=https://garden.jammin-dev.com/api/v1

# External APIs
OPENWEATHER_API_KEY=your_openweathermap_api_key
GEONAMES_USERNAME=your_geonames_username

# Set to True only for local dev (enables /docs and /openapi.json)
DEBUG=False
